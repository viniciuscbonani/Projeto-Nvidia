# LLM do Extractor: se GROQ_API_KEY existir, usa Groq (gpt-oss, grátis);
# senão cai para OpenAI. OPENAI_API_KEY ainda é usada para embeddings (RAG, Fase 4).
GROQ_API_KEY=gsk-coloque-aqui
OPENAI_API_KEY=sk-coloque-aqui
COHERE_API_KEY=coloque-aqui
GEMINI_API_KEY=coloque-aqui

# Banco relacional — Postgres via Docker (docker compose up -d).
DATABASE_URL=postgresql+psycopg://radar:radar@localhost:5432/radar
# Alternativa sem servidor (SQLite embarcado):
# DATABASE_URL=sqlite:///radar.db

# Banco vetorial — Qdrant servidor via Docker.
QDRANT_URL=http://localhost:6333
# Alternativa sem servidor (Qdrant local embarcado): deixe QDRANT_URL vazio e use
# QDRANT_PATH=./qdrant
