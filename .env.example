OPENAI_API_KEY=sk-coloque-aqui
COHERE_API_KEY=coloque-aqui

# Banco relacional — SQLite embarcado (arquivo local, sem servidor)
DATABASE_URL=sqlite:///radar.db

# Banco vetorial — Qdrant em modo local (path local, sem servidor)
# Depois, para Qdrant-servidor (Docker), troque por QDRANT_URL=http://localhost:6333
QDRANT_PATH=./qdrant
